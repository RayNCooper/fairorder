{
  "name": "fairorder-app",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0",
  "scripts": {
    "dotenvx": "dotenvx",
    "dev": "dotenvx run -- next dev",
    "dev:local": "next dev",
    "build": "dotenvx run -- prisma generate && dotenvx run -- next build",
    "build:local": "prisma generate && next build",
    "start": "dotenvx run -- next start",
    "start:local": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:migrate:local": "prisma migrate dev",
    "db:seed": "npx tsx --env-file=.env prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "npx tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@dotenvx/dotenvx": "^1.57.1",
    "@hookform/resolvers": "^5.2.2",
    "@paypal/paypal-server-sdk": "^2.2.0",
    "@paypal/react-paypal-js": "^9.1.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/components": "^1.0.10",
    "@stripe/stripe-js": "^8.11.0",
    "@tabler/icons-react": "^3.31.0",
    "ai": "^6.0.137",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "motion": "^12.26.1",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.3",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-fast-marquee": "^1.6.5",
    "react-hook-form": "^7.71.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prisma": "^7.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
